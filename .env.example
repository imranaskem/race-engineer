ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: override the ElevenLabs voice (default is a neutral male engineer voice)
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Push-to-talk input — "keyboard" (default) or "joystick"
# PTT_TYPE=keyboard

# Keyboard PTT key — pynput key name, e.g. "space", "f1", "ctrl"
# PTT_KEY=space

# Joystick/wheel PTT — device index and button code from the `inputs` library
# Run with PTT_TYPE=joystick to see all button codes logged so you can find yours
# PTT_JOYSTICK_DEVICE=0
# PTT_JOYSTICK_BUTTON=BTN_TRIGGER
